{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "manifest.json",
          "googlea47b5b272cc519bc.html",
          "login.html",
          "register.html",
          "profile.html",
          "destinations.html",
          "jeep-safaris.html",
          "trip-planner.html",
          "book.html",
          "reviews.html",
          "deals.html",
          "contact.html",
          "css/**",
          "js/**",
          "images/**",
          "admin/**",
          "developer/**",
          "videos/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/admin/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/developer/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
